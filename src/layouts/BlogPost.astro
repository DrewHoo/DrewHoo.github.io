---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_AUTHOR } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = heroImage ? new URL(heroImage, Astro.site).href : undefined;
const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
	...(imageURL ? { image: imageURL } : {}),
	author: {
		'@type': 'Person',
		name: SITE_AUTHOR,
		url: new URL('about/', Astro.site).href,
	},
	publisher: { '@type': 'Person', name: SITE_AUTHOR },
	mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.href },
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			ogType="article"
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body>
		<Header />
		<main>
			<p class="back"><a href="/">← back to the blog</a></p>

			<article>
				<header class="post-head">
					<p class="date">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="last-updated">
									· updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</p>
					<h1>{title}</h1>
					<p class="desc">{description}</p>
					{
						heroImage && (
							<img class="hero" width={1020} height={510} src={heroImage} alt="" />
						)
					}
				</header>

				<div class="prose">
					<slot />
				</div>
			</article>

			<section class="comments" aria-label="Comments">
				<!-- Same giscus config as public/embed/giscus.js: threads keyed by
				     pathname, stored in this repo's Discussions (category: Comments). -->
				<script
					is:inline
					src="https://giscus.app/client.js"
					data-repo="DrewHoo/DrewHoo.github.io"
					data-repo-id="R_kgDOSG5Iaw"
					data-category="Comments"
					data-category-id="DIC_kwDOSG5Ia84C7OFV"
					data-mapping="pathname"
					data-strict="0"
					data-reactions-enabled="1"
					data-emit-metadata="0"
					data-input-position="bottom"
					data-theme="preferred_color_scheme"
					data-lang="en"
					crossorigin="anonymous"
					async></script>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.back {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 0.9rem;
		margin: 0 0 1.5rem;
	}
	.post-head {
		margin-bottom: 2rem;
	}
	.date {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 0.85rem;
		color: var(--ink-soft);
		margin: 0 0 0.5rem;
	}
	.last-updated {
		font-style: italic;
	}
	.desc {
		font-size: 1.15rem;
		color: var(--ink-soft);
		max-width: 56ch;
	}
	.hero {
		margin-top: 1.5rem;
		width: 100%;
	}
	.prose {
		max-width: var(--measure);
	}
	.comments {
		margin-top: 3rem;
		max-width: var(--measure);
	}
</style>
