---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`blog — ${SITE_TITLE}`}
			description="Writing about data, visualization, and the occasional tangent."
		/>
	</head>
	<body>
		<Header />
		<main>
			<p class="kicker">// blog</p>
			<h1>Words and charts.</h1>

			{
				posts.length === 0 ? (
					<p class="empty">
						Nothing here yet. Come back later, or poke around the <a href="/">
							projects
						</a>
						.
					</p>
				) : (
					<ul class="posts" role="list">
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h3>{post.data.title}</h3>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
										{post.data.aiWritten && (
											<span
												class="ai-badge"
												title="The hands-on work and first draft were done by Drew's agent (Claude Code), under Drew's direction."
											>
												🤖 written by drew's agent
											</span>
										)}
									</p>
									<p class="desc">{post.data.description}</p>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.kicker {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 0.9rem;
		color: var(--hot);
		margin: 0 0 0.5rem;
	}
	.empty {
		font-size: 1.1rem;
		color: var(--ink-soft);
		max-width: 56ch;
	}
	.posts {
		list-style: none;
		padding: 0;
		margin: 1.5rem 0 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		max-width: none;
	}
	.posts li {
		margin: 0;
	}
	.posts a {
		display: block;
		padding: 1rem 1.25rem;
		border: 2px solid var(--rule);
		background-color: var(--paper);
		color: var(--ink);
		text-decoration: none;
		box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--rule);
		transition: transform 120ms ease-out, box-shadow 120ms ease-out;
	}
	.posts a:hover {
		background-color: var(--paper);
		transform: translate(2px, 2px);
		box-shadow: var(--shadow-offset-pressed) var(--shadow-offset-pressed) 0 var(--rule);
	}
	.posts h3 {
		margin: 0 0 0.25rem;
		font-size: 1.15rem;
	}
	.date {
		margin: 0 0 0.5rem;
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 0.8rem;
		color: var(--ink-soft);
		max-width: none;
	}
	.ai-badge {
		display: inline-block;
		margin-left: 0.6rem;
		padding: 0.1em 0.5em;
		font-size: 0.7rem;
		letter-spacing: 0.02em;
		border: 1.5px solid var(--rule);
		background-color: var(--acid);
		color: var(--acid-ink);
		vertical-align: middle;
		white-space: nowrap;
	}
	@media (prefers-color-scheme: dark) {
		/* no glowing chip in the dark — quiet outline instead */
		.ai-badge {
			background-color: transparent;
			border-color: var(--acid);
			color: var(--acid);
		}
	}
	.desc {
		margin: 0;
		max-width: none;
		font-size: 0.95rem;
	}
	@media (prefers-reduced-motion: reduce) {
		.posts a {
			transition: none;
		}
		.posts a:hover {
			transform: none;
		}
	}
</style>
