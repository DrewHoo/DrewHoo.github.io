---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, GITHUB_URL } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`about — ${SITE_TITLE}`}
			description="About Drew Hoover — software engineer, data-viz hobbyist."
		/>
	</head>
	<body>
		<Header />
		<main>
			<article class="prose">
				<p class="kicker">// about</p>
				<h1>Who's behind this.</h1>

				<p>
					Hi — I'm Drew. I build software for a living and, on weekends, I
					build small tools for exploring datasets that I find interesting.
					This site collects those tools in one place so I can send people a
					single link.
				</p>

				<p>
					Each project has its own repo and its own deployment on GitHub
					Pages, so the index you landed on is really just a directory — a
					card for each thing, a couple of paragraphs about how it was built,
					and a link out.
				</p>

				<p>
					The blog (when I get around to filling it) will be for the "here's
					what I learned scraping Wikipedia for hours" kind of writing. MDX
					lets me embed the charts I make right into the post, which is most
					of why I picked this stack.
				</p>

				<p>
					Reach me on <a href={GITHUB_URL} rel="me noopener">GitHub</a>.
				</p>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.kicker {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 0.9rem;
		color: var(--hot);
		margin: 0 0 0.5rem;
	}
	.prose {
		max-width: 62ch;
	}
</style>
