---
import type { CollectionEntry } from 'astro:content';
import { emphasize } from '../lib/blurb';

interface Props {
	project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, blurb, liveUrl, repoUrl, tags, cover, coverAlt } = project.data;
const liveHost = new URL(liveUrl).host + new URL(liveUrl).pathname.replace(/\/$/, '');
---

<article class="card">
	{
		cover && (
			<a class="cover" href={liveUrl} target="_blank" rel="noopener" tabindex="-1" aria-hidden="true">
				<img
					src={cover}
					alt={coverAlt ?? `Screenshot of ${title}`}
					loading="lazy"
					decoding="async"
					width="800"
					height="500"
				/>
			</a>
		)
	}

	<header class="card-head">
		<h3 class="title">
			<a href={liveUrl} target="_blank" rel="noopener">
				{title}<span class="arrow" aria-hidden="true">&nbsp;↗</span>
				<span class="sr-only">(opens in new tab)</span>
			</a>
		</h3>
		<p class="url"><span aria-hidden="true">→ </span>{liveHost}</p>
	</header>

	<p class="blurb" set:html={emphasize(blurb)} />

	{
		tags.length > 0 && (
			<ul class="tags" aria-label="Tags">
				{tags.map((t) => (
					<li>{t}</li>
				))}
			</ul>
		)
	}

	<footer class="card-foot">
		<a class="primary" href={liveUrl} target="_blank" rel="noopener">
			give it a go<span class="arrow" aria-hidden="true">&nbsp;↗</span>
			<span class="sr-only">(opens in new tab)</span>
		</a>
		{
			repoUrl && (
				<a class="secondary" href={repoUrl} target="_blank" rel="noopener">
					look at the source code
				</a>
			)
		}
	</footer>
</article>

<style>
	.card {
		background-color: var(--paper);
		border: 2px solid var(--rule);
		box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--rule);
		padding: 1.25rem 1.25rem 1.1rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		transition: transform 120ms ease-out, box-shadow 120ms ease-out;
	}
	.card:hover,
	.card:focus-within {
		transform: translate(2px, 2px);
		box-shadow: var(--shadow-offset-pressed) var(--shadow-offset-pressed) 0 var(--rule);
	}
	@media (prefers-reduced-motion: reduce) {
		.card {
			transition: none;
		}
		.card:hover,
		.card:focus-within {
			transform: none;
		}
	}
	.cover {
		display: block;
		margin: -1.25rem -1.25rem 0;
		border-bottom: 2px solid var(--rule);
		background-color: var(--paper-deep);
	}
	.cover img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 8 / 5;
		object-fit: cover;
	}
	.card-head {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}
	.title {
		margin: 0;
		font-size: 1.2rem;
		line-height: 1.25;
	}
	.title a {
		color: var(--ink);
		text-decoration: underline;
		text-decoration-thickness: 2px;
		text-decoration-color: var(--hot);
		text-underline-offset: 4px;
	}
	.title a:hover {
		background: var(--acid);
		color: var(--acid-ink);
	}
	.arrow {
		display: inline-block;
	}
	.url {
		margin: 0;
		max-width: none;
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 0.78rem;
		color: var(--ink-soft);
		word-break: break-all;
	}
	.blurb {
		margin: 0;
		max-width: none;
		font-size: 1rem;
		line-height: 1.55;
	}
	.tags {
		list-style: none;
		padding: 0;
		margin: 0;
		max-width: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}
	.tags li {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 0.72rem;
		padding: 0.15em 0.5em;
		border: 1px solid var(--rule);
		background-color: var(--paper-deep);
		margin: 0;
	}
	.card-foot {
		margin-top: auto;
		padding-top: 0.5rem;
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.5rem 1rem;
		border-top: 1px dashed var(--ink-soft);
	}
	.primary {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-weight: 700;
		font-size: 0.9rem;
		color: var(--hot);
		text-decoration-thickness: 2px;
	}
	.secondary {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 0.85rem;
		color: var(--ink-soft);
	}
</style>
