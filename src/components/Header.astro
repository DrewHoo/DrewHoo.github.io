---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<a class="wordmark" href="/" aria-label={`${SITE_TITLE} — home`}>
			<span>{SITE_TITLE}</span>
		</a>
		<ul class="links">
			<li><HeaderLink href="/">index</HeaderLink></li>
			<li><HeaderLink href="/blog">blog</HeaderLink></li>
			<li><HeaderLink href="/about">about</HeaderLink></li>
		</ul>
	</nav>
</header>

<style>
	header {
		border-bottom: 2px solid var(--rule);
		background-color: var(--paper);
	}
	nav {
		max-width: var(--container);
		margin: 0 auto;
		padding: 1rem 1.25rem;
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem 1.5rem;
	}
	.wordmark {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-weight: 700;
		font-size: 1.35rem;
		color: var(--ink);
		text-decoration: underline;
		text-decoration-color: var(--hot);
		text-decoration-thickness: 3px;
		text-underline-offset: 5px;
		letter-spacing: -0.02em;
	}
	.wordmark:hover {
		background-color: transparent;
		color: var(--hot);
	}
	.links {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem 1.25rem;
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 0.95rem;
	}
	@media (max-width: 520px) {
		nav {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
