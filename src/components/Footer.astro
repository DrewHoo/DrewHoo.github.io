---
import { GITHUB_URL, SITE_TITLE } from '../consts';
const year = new Date().getFullYear();
---

<footer>
	<div class="inner">
		<p class="line">
			<span>{SITE_TITLE}</span>
			<span aria-hidden="true"> · </span>
			<span>© {year}</span>
			<span aria-hidden="true"> · </span>
			<a href={GITHUB_URL} rel="me noopener">github</a>
			<span aria-hidden="true"> · </span>
			<a href="/rss.xml">rss</a>
		</p>
		<p class="colophon">
			Hand-rolled with Astro. Set in Space Mono &amp; Atkinson Hyperlegible.
		</p>
	</div>
</footer>

<style>
	footer {
		border-top: 2px solid var(--rule);
		background-color: var(--paper);
		margin-top: 4rem;
	}
	.inner {
		max-width: var(--container);
		margin: 0 auto;
		padding: 1.5rem 1.25rem 2.5rem;
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 0.85rem;
		color: var(--ink-soft);
	}
	.line {
		margin: 0 0 0.5rem;
		max-width: none;
	}
	.colophon {
		margin: 0;
		max-width: none;
		font-style: italic;
	}
</style>
